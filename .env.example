# ═══════════════════════════════════════════════
# 云上归墅 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ═══════════════════════════════════════════════

# 基础配置
BASE_URL=http://127.0.0.1:5000
DEBUG=true
SECRET_KEY=请更换为强随机字符串，生产环境用: openssl rand -hex 32

# 微信公众号配置（在公众号后台获取）
WECHAT_TOKEN=请填写你设置的Token
WECHAT_APP_ID=请填写你的AppID
WECHAT_APP_SECRET=请填写你的AppSecret
WECHAT_ENCODING_AES_KEY=

# AI 配置 — DeepSeek（Anthropic 兼容接口）
# 支持任何 Anthropic 兼容 API：DeepSeek / Claude / 自定义
ANTHROPIC_API_KEY=sk-你的API密钥
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
AI_MODEL=deepseek-chat
# AI 并发控制
AI_MAX_CONCURRENCY=5
AI_MAX_MESSAGE_LENGTH=500

# 微信支付（开通后获取）
WECHAT_MCH_ID=
WECHAT_MCH_KEY=

# 数据库
# 开发环境默认 SQLite（无需修改）
# 生产环境 PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=
# PostgreSQL 连接池参数（仅 postgresql 时生效）
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
