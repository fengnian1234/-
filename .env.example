# ═══════════════════════════════════════════════
# 云上归墅 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ═══════════════════════════════════════════════

# 基础配置
BASE_URL=http://127.0.0.1:5000
DEBUG=true
SECRET_KEY=请更换为随机字符串

# 微信公众号配置（在公众号后台获取）
WECHAT_TOKEN=请填写你设置的Token
WECHAT_APP_ID=请填写你的AppID
WECHAT_APP_SECRET=请填写你的AppSecret
WECHAT_ENCODING_AES_KEY=

# AI配置（可选，不填则使用关键词自动回复）
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
