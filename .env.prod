# ══════════════════════════════════════════════════════════
# 云上归墅 · 生产环境配置
# 使用方式：docker compose --env-file .env.prod up -d
# ══════════════════════════════════════════════════════════

# ── 基础配置 ─────────────────────────────────────────────
BASE_URL=https://your-domain.com
DEBUG=false
SECRET_KEY=<填写一个强随机字符串，例如: openssl rand -hex 32>

# ── 数据库（Docker Compose 自动使用 postgresql，无需修改）──
DATABASE_URL=postgresql://yunshang:yunshang_prod_2026@db:5432/yunshang_bnb
DB_PASSWORD=yunshang_prod_2026

# ── 微信公众号配置 ───────────────────────────────────────
WECHAT_TOKEN=<公众号后台填写的Token>
WECHAT_APP_ID=<公众号AppID>
WECHAT_APP_SECRET=<公众号AppSecret>
WECHAT_ENCODING_AES_KEY=<消息加解密密钥>

# ── AI 配置（DeepSeek / Anthropic 兼容接口）────────────────
ANTHROPIC_API_KEY=<你的API Key>
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
AI_MODEL=deepseek-chat

# ── 微信支付 ─────────────────────────────────────────────
WECHAT_MCH_ID=<微信支付商户号>
WECHAT_MCH_KEY=<微信支付API密钥>
