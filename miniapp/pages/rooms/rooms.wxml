<page-header title="房型展示" desc="山野之间，总有一间属于你" />

<notice-bar
  type="warning"
  icon="📌"
  title="预订须知"
  items="{{noticeItems}}"
/>

<block wx:if="{{!loading && rooms.length}}">
  <room-card wx:for="{{rooms}}" wx:key="id" room="{{item}}" bind:tap="onRoomTap" />
</block>
<loading-skeleton wx:elif="{{loading}}" visible="{{true}}" rows="{{[{width:680},{width:600},{width:640},{width:500}]}}" />
<empty-state wx:else icon="🏡" text="暂无房型信息" />

<view class="booking-cta">
  <view class="btn btn-primary btn-block" bindtap="onBookingTap">查看预订平台 →</view>
</view>
