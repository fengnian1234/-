.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f0;
}

/* 快捷提示 */
.quick-hints {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  white-space: nowrap;
  flex-shrink: 0;
}
.hint-tag {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  background: #e8f0ea;
  color: #4a7c59;
  font-size: 24rpx;
}

/* 聊天区 */
.chat-area {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}
.chat-sys {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  padding: 16rpx 24rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}
.chat-bubble {
  max-width: 78%;
  padding: 18rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 20rpx;
  word-break: break-word;
  white-space: pre-wrap;
  animation: fadeUp 0.25s;
}
.chat-bubble.me {
  align-self: flex-end;
  margin-left: auto;
  background: #95ec69;
  border-radius: 8rpx 24rpx 24rpx 24rpx;
}
.chat-bubble.you {
  align-self: flex-start;
  background: #fff;
  border-radius: 8rpx 24rpx 24rpx 24rpx;
}
.chat-meta {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}

/* 打字动画 */
.chat-typing {
  align-self: flex-start;
  padding: 18rpx 28rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  gap: 8rpx;
}
.chat-typing .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bbb;
  animation: bounce 1.4s infinite;
}
.chat-typing .dot:nth-child(2) { animation-delay: 0.2s; }
.chat-typing .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-12rpx); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 输入区 */
.chat-input-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  align-items: center;
  flex-shrink: 0;
}
.chat-input {
  flex: 1;
  padding: 14rpx 24rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f5f6f7;
}
.chat-send-btn {
  padding: 14rpx 28rpx;
  background: #4a7c59;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: none;
  line-height: 1;
}
.chat-reset-btn {
  padding: 14rpx 20rpx;
  background: transparent;
  color: #999;
  border: 1rpx solid #e5e5e5;
  border-radius: 40rpx;
  font-size: 22rpx;
  line-height: 1;
}
