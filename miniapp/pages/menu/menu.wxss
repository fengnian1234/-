/* 推荐横向滚动 */
.recommended-scroll {
  padding: 0 var(--space-md);
  white-space: nowrap;
}

.recommended-inner {
  display: inline-flex;
  gap: var(--space-sm);
}

.recommended-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-sm);
  width: 200rpx;
  white-space: normal;
}

.recommended-item__img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-xs);
}

.recommended-item__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-dark);
  font-size: 56rpx;
}

.recommended-item__name {
  font-size: 24rpx;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  width: 100%;
}

.recommended-item__price {
  font-size: 24rpx;
  font-weight: 500;
}

/* 分类 */
.menu-category {
  margin-bottom: var(--space-md);
}

.menu-category__title {
  padding: var(--space-md);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
  font-family: var(--font-serif);
  letter-spacing: 0.04em;
}

/* 购物车 FAB */
.cart-fab {
  position: fixed;
  bottom: 160rpx;
  right: var(--space-md);
  width: 96rpx;
  height: 96rpx;
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  z-index: 100;
  transition: all 0.3s;
}

.cart-fab--active {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.cart-fab__icon {
  font-size: 44rpx;
}

.cart-fab__badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
