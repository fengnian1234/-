.page-header {
  padding: var(--space-xl) var(--space-md);
  background: linear-gradient(170deg, var(--color-sky) 0%, var(--color-primary-dark) 100%);
  color: #fff;
}

.page-header__title {
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 600;
  display: block;
}

.page-header__desc {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: var(--space-xs);
  display: block;
}

.platform-list {
  padding: var(--space-md);
}

.platform-item {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
}

.platform-item__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  flex-shrink: 0;
}

.platform-item__info {
  flex: 1;
}

.platform-item__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.platform-item__tip {
  font-size: 22rpx;
  color: var(--color-text-lighter);
}

.platform-item__arrow {
  font-size: 28rpx;
  color: var(--color-text-lighter);
}

.note {
  padding: var(--space-md);
  margin: 0 var(--space-md);
  background: rgba(74, 124, 89, 0.06);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-light);
}

.note text {
  display: block;
  line-height: 1.6;
}

.contact {
  padding: var(--space-lg);
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text);
}

.contact__phone {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 700;
  margin-top: var(--space-sm);
}
