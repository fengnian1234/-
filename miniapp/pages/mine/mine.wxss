/* 用户头部 */
.user-header {
  position: relative;
  padding: 80rpx var(--space-md) var(--space-lg);
  overflow: hidden;
}

.user-header__bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(170deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
}

.user-header__content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.user-header__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
}

.user-header__name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  font-family: var(--font-serif);
}

.user-header__level {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
}

.user-header__points {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  gap: var(--space-xs);
  background: rgba(255,255,255,0.15);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

.user-header__points-num {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}

.user-header__points-label {
  color: rgba(255,255,255,0.7);
  font-size: 26rpx;
  align-self: flex-end;
}

/* 积分预览 */
.points-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md);
  margin: var(--space-md);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text);
}

.points-preview__left, .points-preview__right {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.points-preview__icon { font-size: 32rpx; }
.points-preview__right { color: var(--color-text-light); font-size: 24rpx; }

/* 功能列表 */
.nav-list {
  margin: 0 var(--space-md);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.nav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md);
  border-bottom: 1px solid var(--color-border);
}

.nav-item:last-child { border-bottom: none; }

.nav-item__left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: 28rpx;
  color: var(--color-text);
}

.nav-item__icon { font-size: 36rpx; width: 48rpx; text-align: center; }

.nav-item__arrow {
  font-size: 28rpx;
  color: var(--color-text-lighter);
}

/* 页脚 */
.footer {
  padding: var(--space-xl) var(--space-md);
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  font-size: 22rpx;
  color: var(--color-text-lighter);
  margin-top: var(--space-xl);
}
