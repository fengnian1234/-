/* ====== Hero 区域 ====== */
.hero {
  position: relative;
  padding: 120rpx var(--space-md) 80rpx;
  text-align: center;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  top: -200rpx; left: -100rpx; right: -100rpx; bottom: 0;
  background:
    radial-gradient(ellipse 80% 60% at 30% 20%, rgba(142, 184, 201, 0.35) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 70% 40%, rgba(200, 150, 106, 0.25) 0%, transparent 60%),
    radial-gradient(ellipse 100% 80% at 50% 80%, rgba(74, 124, 89, 0.15) 0%, transparent 50%),
    linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-light) 100%);
}

.hero__content { position: relative; z-index: 1; }

.hero__tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(74, 124, 89, 0.08);
  color: var(--color-primary-dark);
  font-size: 22rpx;
  margin-bottom: var(--space-md);
}

.hero__title {
  font-family: var(--font-serif);
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 0.18em;
  margin-bottom: var(--space-sm);
}

.hero__subtitle {
  font-size: 30rpx;
  color: var(--color-text-light);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.06em;
}

.hero__poem {
  font-family: var(--font-serif);
  font-size: 24rpx;
  color: var(--color-text-lighter);
  font-style: italic;
  letter-spacing: 0.04em;
}

.hero__wave {
  position: absolute;
  bottom: -2rpx; left: 0; right: 0;
  height: 60rpx;
  background: var(--color-bg-light);
  clip-path: polygon(0 100%, 0 40%, 15% 20%, 30% 50%, 45% 25%, 60% 45%, 75% 20%, 90% 40%, 100% 10%, 100% 100%);
}

/* ====== 快捷入口 ====== */
.quick-nav {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-sm);
  padding: var(--space-md);
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.quick-nav__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) var(--space-sm);
  background: var(--color-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  gap: var(--space-xs);
}

.quick-nav__icon { font-size: 48rpx; }
.quick-nav__label { font-size: 22rpx; color: var(--color-text); font-weight: 500; }

/* ====== 民宿介绍 4 宫格 ====== */
.intro-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
  padding: 0 var(--space-md);
}

.intro-item {
  padding: var(--space-md);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  text-align: center;
}

.intro-item__icon { font-size: 48rpx; display: block; margin-bottom: var(--space-xs); }
.intro-item__title { font-size: 26rpx; font-weight: 600; color: var(--color-text); display: block; margin-bottom: 4rpx; }
.intro-item__desc { font-size: 22rpx; color: var(--color-text-light); display: block; line-height: 1.5; }

/* ====== 精选房型横向滚动 ====== */
.rooms-preview-scroll {
  white-space: nowrap;
  padding: 0 var(--space-md);
}

.rooms-preview-inner {
  display: inline-flex;
  gap: var(--space-sm);
}

.rooms-preview-inner .room-card {
  width: 560rpx;
  flex-shrink: 0;
  white-space: normal;
}

.view-all {
  text-align: center;
  padding: var(--space-md);
  color: var(--color-primary);
  font-size: 26rpx;
}

/* ====== 智能管家功能 ====== */
.features {
  padding: 0 var(--space-md);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}

.feature-item__icon { font-size: 44rpx; flex-shrink: 0; }
.feature-item__text { display: flex; flex-direction: column; }
.feature-item__title { font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 4rpx; }
.feature-item__desc { font-size: 24rpx; color: var(--color-text-light); line-height: 1.5; }

/* ====== 评价轮播 ====== */
.review-carousel {
  height: 460rpx;
  margin: 0 var(--space-md);
}

.review-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
  padding: var(--space-sm);
}

.review-card {
  padding: var(--space-md);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.review-card__stars { font-size: 22rpx; margin-bottom: var(--space-xs); }
.review-card__text { font-size: 22rpx; color: var(--color-text); line-height: 1.5; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.review-card__author { display: flex; align-items: center; gap: var(--space-xs); margin-top: var(--space-sm); }
.review-card__avatar { font-size: 32rpx; }
.review-card__name { font-size: 22rpx; color: var(--color-text); display: block; }
.review-card__date { font-size: 20rpx; color: var(--color-text-lighter); }

/* ====== FAQ ====== */
.faq-list { padding: 0 var(--space-md); }
.faq-item { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); margin-bottom: var(--space-xs); overflow: hidden; }
.faq-item--open { border-color: var(--color-primary-light); }
.faq-item__q { display: flex; justify-content: space-between; align-items: center; padding: var(--space-md); font-size: 26rpx; color: var(--color-text); }
.faq-item__arrow { font-size: 20rpx; color: var(--color-text-lighter); }
.faq-item__a { padding: 0 var(--space-md) var(--space-md); font-size: 24rpx; color: var(--color-text-light); line-height: 1.7; }

/* ====== 页脚 ====== */
.footer {
  padding: var(--space-xl) var(--space-md);
  text-align: center;
  background: linear-gradient(180deg, var(--color-bg-light) 0%, var(--color-primary-dark) 100%);
  color: rgba(255,255,255,0.8);
  margin-top: var(--space-xl);
}

.footer__poem {
  font-family: var(--font-serif);
  font-size: 26rpx;
  margin-bottom: var(--space-md);
  color: rgba(255,255,255,0.9);
}

.footer__info {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
  font-size: 22rpx;
  opacity: 0.75;
}

.footer__phone { color: rgba(255,255,255,0.95); padding: 8rpx 0; }
