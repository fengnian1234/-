/**
 * 云上归墅 · 排版系统
 */

/* ── 标题层级 ──────────────────────────────────────── */
.h1, .h2, .h3, .h4, .h5, .h6 {
  font-family: var(--font-serif);
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: 0.04em;
}

.h1 { font-size: 52rpx; }
.h2 { font-size: 44rpx; }
.h3 { font-size: 36rpx; }
.h4 { font-size: 32rpx; }
.h5 { font-size: 28rpx; }
.h6 { font-size: 24rpx; }

/* ── 正文 ─────────────────────────────────────────── */
.body-text {
  font-family: var(--font-sans);
  font-size: 28rpx;
  line-height: 1.85;
  color: var(--color-text);
}

.body-text--light {
  color: var(--color-text-light);
}

.body-text--lighter {
  color: var(--color-text-lighter);
  font-size: 24rpx;
}

/* ── 区块标题 ─────────────────────────────────────── */
.section-title {
  font-family: var(--font-serif);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  letter-spacing: 0.08em;
  position: relative;
  padding: var(--space-lg) var(--space-md) var(--space-sm);
}

.section-title::before,
.section-title::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 2rpx;
  margin: var(--space-sm) auto;
  background: linear-gradient(
    90deg,
    transparent,
    var(--color-primary-light),
    transparent
  );
}

.section-desc {
  text-align: center;
  color: var(--color-text-light);
  font-size: 26rpx;
  padding: 0 var(--space-lg) var(--space-lg);
  line-height: 1.6;
}

/* ── 价格 ─────────────────────────────────────────── */
.price {
  color: var(--color-accent);
  font-weight: 600;
  font-family: var(--font-sans);
}

.price--large {
  font-size: 40rpx;
}

.price--original {
  color: var(--color-text-lighter);
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: var(--space-xs);
}

/* ── 标签/徽章 ────────────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-family: var(--font-sans);
  line-height: 1.4;
}

.tag--primary {
  background: var(--color-mist);
  color: var(--color-primary-dark);
}

.tag--accent {
  background: rgba(200, 150, 106, 0.15);
  color: var(--color-accent);
}

.tag--success {
  background: rgba(91, 140, 90, 0.12);
  color: var(--color-success);
}

.tag--warning {
  background: rgba(201, 149, 74, 0.12);
  color: var(--color-warning);
}

/* ── 分隔线 ───────────────────────────────────────── */
.divider {
  height: 2rpx;
  background: var(--color-border);
  margin: var(--space-md) 0;
}

.divider--light {
  opacity: 0.5;
}

.divider--dashed {
  border-top: 2rpx dashed var(--color-border);
  height: 0;
  background: none;
}
