.gallery {
  position: relative;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
  background: var(--color-bg-dark);
}

.gallery__swiper {
  width: 100%;
  height: 100%;
}

.gallery__img {
  width: 100%;
  height: 100%;
}

/* 计数器 */
.gallery__counter {
  position: absolute;
  bottom: var(--space-lg);
  right: var(--space-md);
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

/* 箭头 */
.gallery__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.8);
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--color-text);
  z-index: 2;
  box-shadow: var(--shadow-sm);
}

.gallery__arrow--left { left: var(--space-sm); }
.gallery__arrow--right { right: var(--space-sm); }

/* 圆点 */
.gallery__dots {
  position: absolute;
  bottom: var(--space-sm);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
  z-index: 2;
}

.gallery__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  transition: all 0.3s;
}

.gallery__dot--active {
  background: #fff;
  width: 28rpx;
  border-radius: 6rpx;
}
