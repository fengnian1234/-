.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-md);
}

.empty-state__icon {
  font-size: 80rpx;
  margin-bottom: var(--space-md);
  opacity: 0.5;
}

.empty-state__text {
  font-size: 28rpx;
  color: var(--color-text-lighter);
  text-align: center;
  line-height: 1.6;
}
