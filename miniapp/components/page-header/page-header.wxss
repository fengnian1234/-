.page-header {
  position: relative;
  padding: 64rpx var(--space-md) 48rpx;
  background: linear-gradient(
    170deg,
    var(--color-sky) 0%,
    var(--color-primary-dark) 100%
  );
  overflow: hidden;
  color: #fff;
}

.page-header__glow {
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
}

.page-header__content {
  position: relative;
  z-index: 1;
}

.page-header__title {
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-xs);
}

.page-header__desc {
  font-size: 26rpx;
  opacity: 0.85;
  line-height: 1.5;
}

.page-header__wave {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 48rpx;
  background: var(--color-bg);
  clip-path: polygon(0 100%, 0 0, 12% 30%, 28% 0, 44% 25%, 58% 0, 72% 28%, 86% 0, 100% 30%, 100% 100%);
}
