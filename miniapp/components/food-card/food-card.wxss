.food-card {
  display: flex;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin: 0 var(--space-md) var(--space-sm);
}

.food-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

.food-card__img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.food-card__img--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-dark);
  font-size: 56rpx;
}

.food-card__body {
  flex: 1;
  padding: var(--space-sm) var(--space-md);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.food-card__header {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: 4rpx;
}

.food-card__name {
  font-family: var(--font-serif);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.food-card__desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.food-card__meta {
  display: flex;
  gap: var(--space-md);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.food-card__price {
  color: var(--color-accent);
  font-weight: 500;
}

.food-card__address {
  color: var(--color-text-lighter);
}

.food-card__must-try {
  font-size: 22rpx;
  color: var(--color-warning);
  margin-top: 4rpx;
}
